{
    "name": "threadcast-monorepo",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "bun run --filter '*' build",
        "build:cli": "bun run --filter @threadcast/cli build",
        "build:web": "bun run --filter @threadcast/web build",
        "dev:web": "bun run --filter @threadcast/web dev",
        "cli": "cd packages/cli && THREADCAST_CONFIG_DIR=$HOME/.threadcast-dev THREADCAST_API_URL=http://localhost:5173 bun run src/index.tsx",
        "typecheck": "bun run --filter '*' typecheck"
    },
    "devDependencies": {
        "runed": "^0.37.1",
        "web": "^0.0.2"
    }
}
