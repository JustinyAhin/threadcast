{
	"name": "@threadcast/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"gen": "wrangler types",
		"atlas:diff": "atlas migrate diff --env local",
		"atlas:hash": "atlas migrate hash --dir file://drizzle",
		"db:migrate:local": "wrangler d1 migrations apply threadcast-auth --local",
		"db:migrate:remote": "wrangler d1 migrations apply threadcast-auth --remote"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-cloudflare": "^7.2.6",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^22",
		"drizzle-kit": "^0.31.9",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"wrangler": "^4.63.0"
	},
	"dependencies": {
		"@fontsource-variable/bricolage-grotesque": "^5.2.10",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@paralleldrive/cuid2": "^3.3.0",
		"@pierre/diffs": "^1.0.10",
		"@threadcast/shared": "workspace:*",
		"better-auth": "^1.4.18",
		"drizzle-orm": "^0.45.1",
		"marked": "^17.0.2",
		"runed": "^0.37.1",
		"shiki": "^3.22.0",
		"zod": "^4.3.6"
	}
}
