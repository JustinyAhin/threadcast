{
  "name": "@threadcast/cli",
  "version": "0.0.2",
  "type": "module",
  "bin": {
    "threadcast": "bin/threadcast.js"
  },
  "main": "src/index.tsx",
  "scripts": {
    "build": "bun run build.ts",
    "dev": "THREADCAST_CONFIG_DIR=$HOME/.threadcast-dev THREADCAST_API_URL=http://localhost:5173 bun run src/index.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@threadcast/shared": "workspace:*",
    "@opentui/core": "latest",
    "@opentui/solid": "latest",
    "solid-js": "^1.9.0",
    "open": "^10.0.0"
  },
  "devDependencies": {
    "@opentui/core-darwin-arm64": "^0.1.79",
    "@opentui/core-darwin-x64": "^0.1.79",
    "@opentui/core-linux-arm64": "^0.1.79",
    "@opentui/core-linux-x64": "^0.1.79",
    "@types/bun": "^1.3.9",
    "@types/node": "^22",
    "typescript": "^5.9.3"
  }
}
